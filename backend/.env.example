# NS Ticket Tracker — environment variables
# Copy this file to .env and adjust values

# PostgreSQL (production / multi-user)
NS_TICKET_DATABASE_URL=postgresql://user:password@localhost:5432/ns_tickets
# SQLite (development / single-user)
# NS_TICKET_DATABASE_URL=sqlite:///./tickets.db

NS_TICKET_ADMIN_USERNAME=admin
NS_TICKET_ADMIN_PASSWORD=admin
# NS_TICKET_ENFORCE_HTTPS=true  # uncomment for production
